# ============================================
#  Voice AI Assistant — Environment Config
#  Copy this file to .env and fill in your values.
#  Only AWS_REGION and KNOWLEDGE_BASE_ID are required to start.
# ============================================

# ── AWS ──
AWS_REGION=us-east-1
PORT=3000

# ── Bedrock Knowledge Base (required for the search tool) ──
KNOWLEDGE_BASE_ID=YOUR_KNOWLEDGE_BASE_ID

# ── Models (defaults work out of the box) ──
SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0
IMAGE_MODEL_ID=amazon.nova-lite-v1:0

# ── Photo analysis (optional) — set a bucket to enable image upload ──
PHOTOS_BUCKET=

# ── CRM integration (optional) — leave empty to run in demo mode ──
# ARN of a Lambda that talks to your CRM (example format: Salesforce CTI Adapter)
CRM_LAMBDA_ARN=

# ── Amazon Connect escalation (optional) — leave empty for demo mode ──
CONNECT_CALLBACK_LAMBDA_ARN=
ESCALATION_TOPIC_ARN=

# ============================================
#  Branding & Personalization
# ============================================
ASSISTANT_NAME=Voice Assistant
BRAND_NAME=ACME
BRAND_SHORT=AI
BRAND_COLOR=#3B82F6
ACCENT_COLOR=#F59E0B
GREETING=Hi there! 👋
GREETING_SUBTITLE=How can I help you today?

# ── Voice (see README for the full list of Nova Sonic voices) ──
VOICE_ID=matthew
VOICE_LABEL=Matthew (EN-US)

# ── Welcome-screen suggestion chips ──
# Format: "icon|title|description" separated by ";;"
SUGGESTIONS=💡|Ask a question|Get guidance from the knowledge base;;📝|Create a ticket|Log a support case;;📞|Talk to a supervisor|Escalate via phone callback

# ── Optional: override the entire system prompt ──
# SYSTEM_PROMPT=You are a helpful assistant for...
# IMAGE_ANALYSIS_PROMPT=Describe what you see in this workplace photo...
